# ---- Supabase ----
# Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=
# Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings > API > Project API keys > service_role (SERVER ONLY - never expose)
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI ----
OPENAI_API_KEY=
# Optional: override the model used for generation (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ---- Resend (email notifications) ----
RESEND_API_KEY=
# The "from" address. Must be a verified domain/sender in Resend.
RESEND_FROM_EMAIL=AI Chatbot Builder <onboarding@resend.dev>

# ---- App ----
# Public base URL of this app (used to build public chat URLs, embed codes, email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Stripe Billing ----
# Server only. Never expose this value to the browser.
STRIPE_SECRET_KEY=
# Stripe Dashboard > Developers > Webhooks (or `stripe listen` locally)
STRIPE_WEBHOOK_SECRET=
# Publishable key (reserved for Stripe.js/client-side additions)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe test-mode recurring monthly Price IDs (do not mix with live keys/prices).
# Production must use the corresponding live-mode Price IDs instead.
STRIPE_PRICE_LIGHT=price_1TjZ1UFoat2NfwYmBrkP7bCy
STRIPE_PRICE_STANDARD=price_1TjZ1rFoat2NfwYmgmk5zHRq
STRIPE_PRICE_PRO=price_1TjZ2CFoat2NfwYmSBgulHmr
